{
  "name": "kanban-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite",
    "install:all": "npm install && cd client && npm install",
    "test:e2e": "npx playwright test --config=playwright.config.cjs",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report tests/e2e/report"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^8.1.0"
  },
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2"
  }
}