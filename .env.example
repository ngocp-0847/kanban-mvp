# GitHub token for polling (repo scope required)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Seed repo (auto-added on first run)
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo-name

# Server port
PORT=4000

# Session secret — CHANGE THIS to a long random string in production!
SESSION_SECRET=change-me-to-a-long-random-secret

# In production: set to your frontend domain
# CLIENT_ORIGIN=https://kanban.yourdomain.com
# NODE_ENV=production
